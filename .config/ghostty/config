# Font Stuff
font-family = MonoLisa-Black
font-size = 10
adjust-cell-height = 20%

# Window
window-padding-x = 12
window-padding-y = 12
window-decoration = false

# Cursor
shell-integration-features = no-cursor
cursor-style = block
cursor-style-blink = false

# Theme
theme = dark:Ayu, light:Ayu Light

# Terminal Behavior
command = /bin/zsh
mouse-scroll-multiplier = 3
scrollback-limit = 10000
mouse-hide-while-typing = true

# Performance
shell-integration-features = no-cursor
clipboard-paste-protection = false

# Visual Enhancements
background-opacity = 1
background-blur = true
bold-is-bright = true
unfocused-split-opacity = 1

# URL Handling
link-url = true
link-previews = true

# Behavior
scroll-to-bottom = keystroke

# Keybindings
keybind = ctrl+shift+e=new_split:down
keybind = ctrl+shift+i=inspector:toggle
keybind = ctrl+shift+r=reload_config
keybind = ctrl+shift+\=new_split:right
keybind = ctrl+shift+-=new_split:down
keybind = ctrl+shift+h=goto_split:left
keybind = ctrl+shift+j=goto_split:down
keybind = ctrl+shift+k=goto_split:up
keybind = ctrl+shift+l=goto_split:right

# Font Features
font-feature = calt
font-feature = -liga

# Accessibility
working-directory = inherit
